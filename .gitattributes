# Normalize line endings: store and check out text files with LF.
# Stops the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Shell scripts and gradle wrapper must stay LF.
*.sh text eol=lf
gradlew text eol=lf

# Windows batch files stay CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never normalize or diff as text.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.db binary
*.sqlite binary
*.keystore binary
*.jar binary
